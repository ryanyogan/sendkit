{
  "name": "sendkit-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "build:core": "bun run --filter @yogidev/sendkit-core build",
    "build:cli": "bun run --filter @yogidev/sendkit build",
    "build:stdio-mcp": "bun run --filter @yogidev/sendkit-mcp build",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:stdio-mcp": "bun run packages/stdio-mcp/src/index.ts",
    "dev:http-mcp": "bun run apps/http-mcp/src/index.ts",
    "release:pack:core": "bun run --filter @yogidev/sendkit-core pack:dry",
    "release:pack:cli": "bun run --filter @yogidev/sendkit pack:dry",
    "release:pack:stdio-mcp": "bun run --filter @yogidev/sendkit-mcp pack:dry"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
